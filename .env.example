# Student Career & Internship Tracker - Environment Variables Template
# Copy this file to '.env' or '.env.local' and set the variables appropriately.

# The base URL of the DummyJSON API (defaults to https://dummyjson.com)
VITE_DUMMY_JSON_API_URL=https://dummyjson.com

# Optional application settings
VITE_APP_TITLE="Student Career & Internship Tracker"
VITE_ENABLE_MOCK_DELAY=true
